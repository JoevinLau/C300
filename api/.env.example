ECOTRANSIT_API_URL=https://your-licensed-ecotransit-rest-endpoint.example/calculate
ECOTRANSIT_API_TOKEN=your_ecotransit_api_token
# Set this to 1 to use the Playwright web scraper when API credentials are not
# configured. The scraper depends on the public calculator remaining accessible.
ECOTRANSIT_ENABLE_SCRAPER=0
ECOTRANSIT_USERNAME=your_ecotransit_web_username
ECOTRANSIT_PASSWORD=your_ecotransit_web_password
