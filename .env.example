AI_KEY=your_openai_api_key_here

# Required for calculation workflows. The API fails closed when authoritative
# FX, inflation, NAICS, machine, or grid reference data cannot be loaded.
DB_HOST=your_db_host
DB_PORT=4000
DB_USER=your_db_user
DB_PASSWORD=your_db_password
DB_NAME=carbon_emission_db

# You can use this standard OpenAI variable name instead of AI_KEY.
# OPENAI_API_KEY=your_openai_api_key_here
RAG_EMBEDDING_MODEL=text-embedding-3-small
RAG_CHAT_MODEL=gpt-4.1-mini
RAG_TOP_K=6
RAG_SCORE_THRESHOLD=0.25

# Optional: use the Playwright web scraper when EcoTransit API credentials are
# not configured. Depends on the public calculator remaining accessible.
ECOTRANSIT_ENABLE_SCRAPER=0
ECOTRANSIT_USERNAME=your_ecotransit_web_username
ECOTRANSIT_PASSWORD=your_ecotransit_web_password
